{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "functions": {
    "api/backtest.js": {
      "maxDuration": 30
    },
    "api/ai-learning.js": {
      "maxDuration": 30
    },
    "api/picks-stats.js": {
      "maxDuration": 30
    },
    "api/ai-picks-enhanced.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store" }
      ]
    }
  ]
}
